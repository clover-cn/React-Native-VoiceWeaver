{
  "name": "rnmall",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "dev:basic": "react-native bundle-harmony --dev false --entry-file ./index.js --bundle-output ./harmony/entry/src/main/resources/rawfile/bundle/basic/basic.harmony.bundle --config ./basic.config.js",
    "dev:base": "react-native bundle-harmony --dev false --entry-file ./src/ts/modules/base/index.js --bundle-output ./harmony/entry/src/main/resources/rawfile/bundle/base/base.harmony.bundle --assets-dest ./harmony/entry/src/main/resources/rawfile/assets --config ./base.config.js",
    "dev:all": "npm run dev:basic && npm run dev:base",
    "codegen": "react-native codegen-harmony --cpp-output-path ./harmony/entry/src/main/cpp/generated --rnoh-module-path ./harmony/entry/oh_modules/@rnoh/react-native-openharmony"
  },
  "dependencies": {
    "@gorhom/portal": "1.0.14",
    "@react-native-community/checkbox": "0.5.20",
    "@react-native-oh-tpl/react-native-view-shot": "3.8.0-0.3.2",
    "@react-native-oh-tpl/react-native-webview": "13.10.2-0.0.6",
    "@react-native-oh/react-native-harmony": "0.72.82",
    "@react-native-ohos/checkbox": "0.5.17-rc.4",
    "@react-native-ohos/react-native-linear-gradient": "3.0.1-rc.1",
    "@xmldom/xmldom": "^0.9.10",
    "buffer": "^6.0.3",
    "crypto-js": "4.2.0",
    "css-select": "4.3.0",
    "d3-scale-chromatic": "3.1.0",
    "dom-serializer": "2.0.0",
    "domutils": "3.2.2",
    "he": "^1.2.0",
    "htmlparser2": "8.0.2",
    "iconv-lite": "^0.7.2",
    "jsonpath-plus": "^10.4.0",
    "memfs": "4.17.2",
    "react": "18.2.0",
    "react-native": "0.72.5",
    "react-native-bouncy-checkbox": "4.1.2",
    "react-native-element-dropdown": "^2.12.1",
    "react-native-video": "npm:@react-native-ohos/react-native-video@^6.13.2",
    "react-native-waterfall-flow": "1.1.5",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@babel/core": "7.28.0",
    "@babel/preset-env": "7.28.0",
    "@babel/runtime": "7.28.2",
    "@react-native/eslint-config": "0.72.2",
    "@react-native/metro-config": "0.72.12",
    "@tsconfig/react-native": "3.0.6",
    "@types/d3-scale-chromatic": "3.1.0",
    "@types/react": "18.3.23",
    "@types/react-test-renderer": "18.3.1",
    "babel-jest": "29.7.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "2.8.8",
    "react-test-renderer": "18.2.0",
    "turboModules": "file:turboModules",
    "typescript": "4.8.4"
  },
  "overrides": {
    "@react-native-community/cli": "11.3.6"
  },
  "resolutions": {
    "@react-native-community/cli": "11.3.6"
  },
  "engines": {
    "node": ">=16"
  },
  "harmony": {
    "alias": "bridge-func",
    "codegenConfig": {
      "specPaths": [
        "./turboModules/src"
      ]
    }
  }
}
